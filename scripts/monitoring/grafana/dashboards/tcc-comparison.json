{
  "title": "TCC — Java 25 VT vs Go 1.25 vs Quarkus Native",
  "uid": "tcc-comparison",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "5s",
  "time": { "from": "now-10m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Throughput — Requisições por Segundo",
      "description": "Taxa de requests processados por cada modelo de concorrência. Sob carga equivalente com pool proporcional, Java VT e Go devem empatar. Quarkus Native degrada sob carga alta por não ter modelo de threads leves.",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "☕ Java 25 — Virtual Threads" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#F5A623" } }]
          },
          {
            "matcher": { "id": "byName", "options": "🐹 Go 1.25 — Goroutines" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#00ADD8" } }]
          },
          {
            "matcher": { "id": "byName", "options": "⚡ Quarkus Native" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#9933CC" } }]
          }
        ]
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"backend-java\"}[30s]))",
          "legendFormat": "☕ Java 25 — Virtual Threads",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"backend-go\"}[30s]))",
          "legendFormat": "🐹 Go 1.25 — Goroutines",
          "refId": "B"
        },
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"backend-quarkus\"}[30s]))",
          "legendFormat": "⚡ Quarkus Native",
          "refId": "C"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 2,
      "title": "Latência p95 — Tempo de Resposta (95% das requisições)",
      "description": "Percentil 95 da latência. Java VT e Go devem empatar. Quarkus Native degrada sob carga alta por saturação de OS threads aguardando I/O.",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "☕ Java 25 p95" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#F5A623" } }]
          },
          {
            "matcher": { "id": "byName", "options": "🐹 Go 1.25 p95" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#00ADD8" } }]
          },
          {
            "matcher": { "id": "byName", "options": "⚡ Quarkus Native p95" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#9933CC" } }]
          }
        ]
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=\"backend-java\"}[30s])) by (le))",
          "legendFormat": "☕ Java 25 p95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=\"backend-go\"}[30s])) by (le))",
          "legendFormat": "🐹 Go 1.25 p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=\"backend-quarkus\"}[30s])) by (le))",
          "legendFormat": "⚡ Quarkus Native p95",
          "refId": "C"
        }
      ]
    },
    {
      "id": 3,
      "title": "Latência p99 — Cauda Longa (Piores 1%)",
      "description": "Percentil 99. Revela comportamento sob pressão extrema. Quarkus sob carga alta mostrará cauda muito longa por contenção de OS threads.",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "☕ Java 25 p99" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#F5A623" } }]
          },
          {
            "matcher": { "id": "byName", "options": "🐹 Go 1.25 p99" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#00ADD8" } }]
          },
          {
            "matcher": { "id": "byName", "options": "⚡ Quarkus Native p99" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#9933CC" } }]
          }
        ]
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{job=\"backend-java\"}[30s])) by (le))",
          "legendFormat": "☕ Java 25 p99",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{job=\"backend-go\"}[30s])) by (le))",
          "legendFormat": "🐹 Go 1.25 p99",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{job=\"backend-quarkus\"}[30s])) by (le))",
          "legendFormat": "⚡ Quarkus Native p99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 4,
      "title": "Taxa de Erros (5xx)",
      "description": "Percentual de erros. Todos devem ficar abaixo de 1% para o TCC ser válido (threshold do k6).",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.01 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "☕ Java 25 Erros" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#F5A623" } }]
          },
          {
            "matcher": { "id": "byName", "options": "🐹 Go 1.25 Erros" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#00ADD8" } }]
          },
          {
            "matcher": { "id": "byName", "options": "⚡ Quarkus Native Erros" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#9933CC" } }]
          }
        ]
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"backend-java\",outcome=\"SERVER_ERROR\"}[30s])) / sum(rate(http_server_requests_seconds_count{job=\"backend-java\"}[30s]))",
          "legendFormat": "☕ Java 25 Erros",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"backend-go\",outcome=\"SERVER_ERROR\"}[30s])) / sum(rate(http_server_requests_seconds_count{job=\"backend-go\"}[30s]))",
          "legendFormat": "🐹 Go 1.25 Erros",
          "refId": "B"
        },
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"backend-quarkus\",outcome=\"SERVER_ERROR\"}[30s])) / sum(rate(http_server_requests_seconds_count{job=\"backend-quarkus\"}[30s]))",
          "legendFormat": "⚡ Quarkus Native Erros",
          "refId": "C"
        }
      ]
    },
    {
      "id": 5,
      "title": "Modelo de Concorrência — Threads/Goroutines Ativas",
      "description": "Unidades de concorrência ativas por runtime. Java VT: threads totais (Virtual + Platform). Go: goroutines (M:N multiplexadas em GOMAXPROCS OS threads). Quarkus Native: OS threads diretas (sem abstração — satura sob carga alta).",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "☕ Java 25 — Threads Totais (VT + Platform)" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#F5A623" } }]
          },
          {
            "matcher": { "id": "byName", "options": "☕ Java 25 — Threads Executando" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#FFC966" } }]
          },
          {
            "matcher": { "id": "byName", "options": "🐹 Go 1.25 — Goroutines Ativas" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#00ADD8" } }]
          },
          {
            "matcher": { "id": "byName", "options": "⚡ Quarkus Native — OS Threads" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#9933CC" } }]
          }
        ]
      },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{job=\"backend-java\"}",
          "legendFormat": "☕ Java 25 — Threads Totais (VT + Platform)",
          "refId": "A"
        },
        {
          "expr": "jvm_threads_live_threads{job=\"backend-java\", state=\"runnable\"}",
          "legendFormat": "☕ Java 25 — Threads Executando",
          "refId": "B"
        },
        {
          "expr": "go_goroutines{job=\"backend-go\"}",
          "legendFormat": "🐹 Go 1.25 — Goroutines Ativas",
          "refId": "C"
        },
        {
          "expr": "jvm_threads_live_threads{job=\"backend-quarkus\"}",
          "legendFormat": "⚡ Quarkus Native — OS Threads",
          "refId": "D"
        }
      ]
    },
    {
      "id": 6,
      "title": "Footprint de Memória (Heap / RSS)",
      "description": "Heap JVM para Java, heap Go para Go, RSS do processo para Quarkus Native (sem JVM heap). Quarkus Native é a prova de que o custo de RAM é da JVM, não da linguagem Java.",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 24, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "☕ Java 25 — Heap Usado" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#F5A623" } }]
          },
          {
            "matcher": { "id": "byName", "options": "🐹 Go 1.25 — Heap In-Use" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#00ADD8" } }]
          },
          {
            "matcher": { "id": "byName", "options": "⚡ Quarkus Native — RSS (sem JVM)" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#9933CC" } }]
          }
        ]
      },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{job=\"backend-java\", area=\"heap\"})",
          "legendFormat": "☕ Java 25 — Heap Usado",
          "refId": "A"
        },
        {
          "expr": "go_memstats_heap_inuse_bytes{job=\"backend-go\"}",
          "legendFormat": "🐹 Go 1.25 — Heap In-Use",
          "refId": "B"
        },
        {
          "expr": "process_memory_rss_bytes{job=\"backend-quarkus\"}",
          "legendFormat": "⚡ Quarkus Native — RSS (sem JVM)",
          "refId": "C"
        }
      ]
    },
    {
      "id": 7,
      "title": "Uso de CPU",
      "description": "CPU consumida por cada backend. Em I/O bound puro todos devem ficar baixos. CPU alta indica contenção de threads ou GC excessivo.",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 24, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "☕ Java 25 — CPU" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#F5A623" } }]
          },
          {
            "matcher": { "id": "byName", "options": "🐹 Go 1.25 — CPU" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#00ADD8" } }]
          },
          {
            "matcher": { "id": "byName", "options": "⚡ Quarkus Native — CPU" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#9933CC" } }]
          }
        ]
      },
      "targets": [
        {
          "expr": "process_cpu_usage{job=\"backend-java\"}",
          "legendFormat": "☕ Java 25 — CPU",
          "refId": "A"
        },
        {
          "expr": "rate(process_cpu_seconds_total{job=\"backend-go\"}[30s])",
          "legendFormat": "🐹 Go 1.25 — CPU",
          "refId": "B"
        },
        {
          "expr": "process_cpu_usage{job=\"backend-quarkus\"}",
          "legendFormat": "⚡ Quarkus Native — CPU",
          "refId": "C"
        }
      ]
    },
    {
      "id": 8,
      "title": "OS Threads do Runtime Go (go_threads)",
      "description": "Threads de SO criadas pelo runtime Go. Deve permanecer próximo de GOMAXPROCS (nº de vCPUs) mesmo com centenas de goroutines — comprova que goroutines são multiplexadas M:N, não mapeadas 1:1 em OS threads.",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 32, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "🐹 Go — OS Threads Totais" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#00ADD8" } }]
          }
        ]
      },
      "targets": [
        {
          "expr": "go_threads{job=\"backend-go\"}",
          "legendFormat": "🐹 Go — OS Threads Totais",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "GC — Pausas de Garbage Collection (Java ZGC vs Go GC)",
      "description": "Duração das pausas de GC. ZGC do Java 25 deve ser sub-milissegundo. Go GC concurrent também deve ser mínimo. Quarkus Native usa GC nativo (Epsilon/Serial por padrão no Mandrel).",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 32, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "☕ Java 25 — GC Pausa Média (ZGC)" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#F5A623" } }]
          },
          {
            "matcher": { "id": "byName", "options": "🐹 Go 1.25 — GC Pausa Média" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#00ADD8" } }]
          }
        ]
      },
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_sum{job=\"backend-java\"}[30s]) / rate(jvm_gc_pause_seconds_count{job=\"backend-java\"}[30s])",
          "legendFormat": "☕ Java 25 — GC Pausa Média (ZGC)",
          "refId": "A"
        },
        {
          "expr": "rate(go_gc_duration_seconds_sum{job=\"backend-go\"}[30s]) / rate(go_gc_duration_seconds_count{job=\"backend-go\"}[30s])",
          "legendFormat": "🐹 Go 1.25 — GC Pausa Média",
          "refId": "B"
        }
      ]
    },
    {
      "id": 10,
      "title": "Pool de Conexões DB — Utilização Ativa (HikariCP / Agroal)",
      "description": "Conexões PostgreSQL em uso. HikariCP (Java) e Agroal (Quarkus) expõem métricas de pool. Essencial para o experimento de spike: com 500 VUs e pool=200, 60% das threads ficam em espera — comprova a hipótese de contenção.",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 40, "w": 24, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "☕ Java 25 — HikariCP Conexões Ativas" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#F5A623" } }]
          },
          {
            "matcher": { "id": "byName", "options": "☕ Java 25 — HikariCP Threads em Espera" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#FF9800" } }]
          },
          {
            "matcher": { "id": "byName", "options": "☕ Java 25 — HikariCP Pool Máximo" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#FFC107" } }]
          },
          {
            "matcher": { "id": "byName", "options": "⚡ Quarkus Native — Agroal Conexões Ativas" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#9933CC" } }]
          },
          {
            "matcher": { "id": "byName", "options": "⚡ Quarkus Native — Agroal Conexões Criadas" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#BB66EE" } }]
          }
        ]
      },
      "targets": [
        {
          "expr": "hikaricp_connections_active{job=\"backend-java\"}",
          "legendFormat": "☕ Java 25 — HikariCP Conexões Ativas",
          "refId": "A"
        },
        {
          "expr": "hikaricp_connections_pending{job=\"backend-java\"}",
          "legendFormat": "☕ Java 25 — HikariCP Threads em Espera",
          "refId": "B"
        },
        {
          "expr": "hikaricp_connections_max{job=\"backend-java\"}",
          "legendFormat": "☕ Java 25 — HikariCP Pool Máximo",
          "refId": "C"
        },
        {
          "expr": "agroal_connections_active_count{job=\"backend-quarkus\"}",
          "legendFormat": "⚡ Quarkus Native — Agroal Conexões Ativas",
          "refId": "D"
        },
        {
          "expr": "agroal_connections_created_count{job=\"backend-quarkus\"}",
          "legendFormat": "⚡ Quarkus Native — Agroal Conexões Criadas",
          "refId": "E"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 11,
      "title": "Latência Mediana (p50) — Linha de Base de Comparação",
      "description": "Mediana da latência — menos sensível a outliers. Sob carga equivalente (baseline/stress com pool proporcional), Java VT e Go devem convergir para ~350ms (latência do mock externo). Quarkus diverge sob carga por saturação de threads.",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 48, "w": 24, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "☕ Java 25 — Mediana (p50)" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#F5A623" } }]
          },
          {
            "matcher": { "id": "byName", "options": "🐹 Go 1.25 — Mediana (p50)" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#00ADD8" } }]
          },
          {
            "matcher": { "id": "byName", "options": "⚡ Quarkus Native — Mediana (p50)" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#9933CC" } }]
          }
        ]
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{job=\"backend-java\"}[30s])) by (le))",
          "legendFormat": "☕ Java 25 — Mediana (p50)",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{job=\"backend-go\"}[30s])) by (le))",
          "legendFormat": "🐹 Go 1.25 — Mediana (p50)",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{job=\"backend-quarkus\"}[30s])) by (le))",
          "legendFormat": "⚡ Quarkus Native — Mediana (p50)",
          "refId": "C"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 12,
      "title": "RAM Total do Processo (RSS) — Footprint Real",
      "description": "Memória RAM total do processo. Java inclui JVM, metaspace, code cache e stacks. Go e Quarkus Native são binários estáticos — sem JVM overhead. Esta é a evidência central do TCC: o custo de RAM é da JVM, não da linguagem Java.",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 56, "w": 24, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "decbytes",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "☕ Java 25 — RAM Total (RSS)" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#F5A623" } }]
          },
          {
            "matcher": { "id": "byName", "options": "🐹 Go 1.25 — RAM Total (RSS)" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#00ADD8" } }]
          },
          {
            "matcher": { "id": "byName", "options": "⚡ Quarkus Native — RAM Total (RSS)" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#9933CC" } }]
          }
        ]
      },
      "targets": [
        {
          "expr": "process_memory_rss_bytes{job=\"backend-java\"}",
          "legendFormat": "☕ Java 25 — RAM Total (RSS)",
          "refId": "A"
        },
        {
          "expr": "process_resident_memory_bytes{job=\"backend-go\"}",
          "legendFormat": "🐹 Go 1.25 — RAM Total (RSS)",
          "refId": "B"
        },
        {
