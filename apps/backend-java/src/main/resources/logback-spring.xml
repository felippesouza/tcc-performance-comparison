<?xml version="1.0" encoding="UTF-8"?>
<!--
  TCC — Comparacao de Performance: Java 25 vs Go 1.25
  Structured JSON logging com correlationId no MDC.
  Equivalente ao slog.SetDefault(slog.NewJSONHandler(...)) do backend Go.
-->
<configuration>
    <springProperty scope="context" name="appName" source="spring.application.name" defaultValue="backend-java"/>

    <appender name="JSON_STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <providers>
                <timestamp>
                    <fieldName>timestamp</fieldName>
                    <pattern>yyyy-MM-dd'T'HH:mm:ss.SSSZ</pattern>
                </timestamp>
                <logLevel>
                    <fieldName>level</fieldName>
                </logLevel>
                <loggerName>
                    <fieldName>logger</fieldName>
                    <shortenedLoggerNameLength>36</shortenedLoggerNameLength>
                </loggerName>
                <message>
                    <fieldName>message</fieldName>
                </message>
                <mdc>
                    <!-- correlationId e populado pelo CorrelationIdFilter via MDC -->
                </mdc>
                <stackTrace>
                    <fieldName>stackTrace</fieldName>
                </stackTrace>
            </providers>
            <customFields>{"app":"${appName}","runtime":"java25-virtual-threads"}</customFields>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="JSON_STDOUT"/>
    </root>

    <!-- Reduz verbosidade do Hibernate e Spring em logs estruturados -->
    <logger name="org.hibernate" level="WARN"/>
    <logger name="org.springframework.data" level="WARN"/>
    <logger name="com.zaxxer.hikari" level="WARN"/>
</configuration>
